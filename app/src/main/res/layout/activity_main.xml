<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0800"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ═══ HEADER ════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="NAV LISTENER"
                android:textColor="#FFB300"
                android:textSize="22sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"/>

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0"
                android:textColor="#5A4800"
                android:textSize="11sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- ═══ STATUS CARDS ══════════════════════════════════════ -->

        <!-- Listener Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1500"
            android:padding="12dp"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <View
                    android:id="@+id/dotListener"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_red"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NOTIF LISTENER"
                    android:textColor="#7A5500"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvListenerStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Memeriksa..."
                android:textColor="#FF3131"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btnPermission"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="⚠ BERI IZIN NOTIFIKASI"
                android:textColor="#0A0800"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:backgroundTint="#FFB300"/>
        </LinearLayout>

        <!-- MQTT Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1500"
            android:padding="12dp"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <View
                    android:id="@+id/dotMqtt"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_red"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MQTT BROKER"
                    android:textColor="#7A5500"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TX: "
                    android:textColor="#5A4800"
                    android:textSize="11sp"
                    android:fontFamily="monospace"/>

                <TextView
                    android:id="@+id/tvTxCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#39FF14"
                    android:textSize="11sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvMqttStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tidak terhubung"
                android:textColor="#FF3131"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="10dp"/>

            <!-- Channel ID -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHANNEL ID"
                android:textColor="#5A4800"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etChannel"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="#120F00"
                android:padding="10dp"
                android:textColor="#FFE8A0"
                android:textColorHint="#5A4800"
                android:hint="mis: NAVKU001"
                android:inputType="textCapCharacters"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <!-- Broker URI -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BROKER URI"
                android:textColor="#5A4800"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etBroker"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="#120F00"
                android:padding="10dp"
                android:textColor="#39FF14"
                android:textColorHint="#5A4800"
                android:hint="tcp://broker.emqx.io:1883"
                android:inputType="textUri"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="CONNECT MQTT"
                android:textColor="#0A0800"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:backgroundTint="#39FF14"/>
        </LinearLayout>

        <!-- ═══ NAV DATA CARD (tersembunyi sampai ada navigasi) ══ -->
        <LinearLayout
            android:id="@+id/cardNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1500"
            android:padding="14dp"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Header nav card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:id="@+id/dotNav"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_gray"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NAVIGASI AKTIF"
                    android:textColor="#7A5500"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"/>
            </LinearLayout>

            <!-- Arrow + Distance row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <!-- Arrow icon -->
                <ImageView
                    android:id="@+id/imgArrow"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_arrow_up"
                    android:layout_marginEnd="14dp"/>

                <!-- Distance + Maneuver -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- m"
                        android:textColor="#FFB300"
                        android:textSize="32sp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvManeuver"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lurus"
                        android:textColor="#39FF14"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.05"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Street name -->
            <TextView
                android:id="@+id/tvStreet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="---"
                android:textColor="#FFE8A0"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="8dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2D2000"
                android:layout_marginBottom="8dp"/>

            <!-- ETA + Remain -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvEta"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ETA --:--"
                    android:textColor="#7A5500"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>

                <TextView
                    android:id="@+id/tvRemain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- km lagi"
                    android:textColor="#7A5500"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ PANDUAN ════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#120F00"
            android:padding="12dp"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CARA PENGGUNAAN"
                android:textColor="#5A4800"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Klik 'Beri Izin' → aktifkan NavListener\n2. Isi Channel ID (sama dengan ESP8266)\n3. Klik CONNECT MQTT\n4. Buka Google Maps → mulai navigasi\n5. Data otomatis terkirim ke ESP8266!\n\nESP8266 subscribe topic:\nnavmqtt/{channelID}/data"
                android:textColor="#5A4800"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
